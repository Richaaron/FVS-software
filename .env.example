# FVS Software - Email Configuration Template
# Copy this file to .env and configure with your actual settings

# ============================================
# SMTP Email Configuration
# ============================================

# Gmail Configuration Example:
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your-email@gmail.com
SENDER_PASSWORD=your-gmail-app-password

# For Gmail:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use the 16-character app password as SENDER_PASSWORD

# Alternative SMTP Providers:
# Microsoft Outlook: smtp-mail.outlook.com:587
# Yahoo Mail: smtp.mail.yahoo.com:587
# SendGrid: smtp.sendgrid.net:587 (use "apikey" as username, API key as password)
# AWS SES: email-smtp.region.amazonaws.com:587

# ============================================
# Application Settings
# ============================================

# Base URL for email links (adjust to your deployment)
APP_URL=http://localhost:5000

# Flask Secret Key (change in production!)
SECRET_KEY=dev-secret-key-change-in-production

# ============================================
# Database Configuration (Optional)
# ============================================

# DATABASE_URL=sqlite:///fvs_results.db

# ============================================
# Flask Configuration
# ============================================

FLASK_ENV=development
